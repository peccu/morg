# Google OAuth 2.0
# Google Cloud Console → 認証情報 → OAuth 2.0 クライアントID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-secret

# 本番: https://your-site.netlify.app/.netlify/functions/auth-callback
# 開発: http://localhost:8888/.netlify/functions/auth-callback
GOOGLE_REDIRECT_URI=http://localhost:8888/.netlify/functions/auth-callback

# Cookie暗号化キー（32文字以上のランダム文字列）
# 生成例: openssl rand -hex 32
COOKIE_SECRET=your-random-secret-at-least-32-chars

# SPAのURL（OAuthコールバック後のリダイレクト先）
APP_URL=http://localhost:5173
